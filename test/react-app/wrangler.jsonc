{
	"name": "vite-plugin-effect",
	"compatibility_date": "2026-06-07",
	"compatibility_flags": [
		"nodejs_compat"
	],
	// Run `bun run build:cloudflare` before `wrangler dev` or `wrangler deploy`.
	"main": "./dist/server/index.js",
	"assets": {
		"directory": "./dist",
		"not_found_handling": "single-page-application",
		"run_worker_first": [
			"/api",
			"/api/*",
			"/rpc",
			"/rpc/*"
		]
	},
	"no_bundle": false
}
